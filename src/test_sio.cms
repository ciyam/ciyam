load "load sio file" <val//name>
save "save sio file" <val//name>
output "output graph (starting at an optional path)" [<opt/-json/json>][<val//path>]
sections "output node's child sections (for an optional path)" [<val//path>]
attribute "output an (optionally path prefixed) node's attribute" <val//name>
attributes "output all node attributes (for an optional path)" [<val//path>]
exit "exit program"
