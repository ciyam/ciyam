load "load sio file" <val//name>
save "save sio file" <val//name>
output "output graph starting at an optional path" [<opt/-json/json>][<val//path>]
sections "output all child sections for an optional path" [<opt/-json/json>][<val//path>]
available "output all available node attributes for an optional path" [<opt/-json/json>][<val//path>]
attributes "output optionally path prefixed node attributes" [<opt/-json/json>]<list//names>
exit "exit program"
