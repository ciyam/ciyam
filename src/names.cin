NAMES=$1
;
@ifndef $NAMES
#Usage: names.cin [name1[,name2[,..]]
@else
CHOICES=&Name: [NAME# (exit)=
;
CIYAM_CHOICE_OUTPUT_REPLACE=1
;
; NOTE: Names provided must be formatted as
; name1[,name2[,..]] or @name1[@name2[@..]]
; (but are not required to be ordered). The
; next steps are necessary to transform the
; latter into the former. And can be viewed
; as follows:
;
; @def@ghi@abc@def
;
; 1. ~@def@ghi@abc@def
; 2. def@ghi@abc@def
; 3. def,ghi,abc,def
;
; Next the names are sorted with duplicates
; (if any were found) having being removed:
;
; abc,def,ghi
;
NAME_INFO=~$NAMES
;
NAME_INFO=@repstr:~@/:$NAME_INFO
NAME_INFO=@repstr:~/:$NAME_INFO
;
NAME_INFO=@repstr:@/,:$NAME_INFO
;
; NOTE: Now sorts the comma separated list
; (removing duplicates if they are found).
; The "head" command removes a final comma
; the appears due to an LF being appended.
NAME_INFO=@file:~echo "$NAME_INFO" | tr "," "\n" | sort | uniq | tr "\n" "," | head -c-1
;
NAME_LINES=@repstr:,/\n:$NAME_INFO
;
@label INIT_NEXT
;
@:INIT_LOOP
;
NEXT_NAME=%NAME_LINES:1%
;
@ifndef $NEXT_NAME
@label END_INIT_LOOP
@endif
;
@skip
;
@:INIT_NEXT
;
CHOICES=$CHOICES|$NEXT_NAME=$NEXT_NAME
;
NAME_LINES=%NAME_LINES:-1%
;
!!@:INIT_LOOP
;
@:END_INIT_LOOP
CHOICES=$CHOICES]
;
DUMMY= <none>
PREFIX=Selected Names
;
NAMES=
SELECTED_NAMES=
;
@label NEXT_NAME
;
#$PREFIX:$DUMMY
;
@:NAME_LOOP
;
$CHOICES
;
@ifeq "$NAME" ""
@label END_NAME_LOOP
@endif
;
@skip
;
@:NEXT_NAME
;
ERASER=
;
@ifndef $SELECTED_NAMES
@ifdef $DUMMY
ERASER=@eraser:$DUMMY
ERASER=$DUMMY,$ERASER
DUMMY=
@endif
SELECTED_NAMES=[$NAME]
@else
CHECK_SELECTED=@repstr:[$NAME]/:$SELECTED_NAMES
;
@ifneq "$CHECK_SELECTED" "$SELECTED_NAMES"
ERASER=@eraser:$NAME,
ERASER=$NAME,$ERASER
SELECTED_NAMES=$CHECK_SELECTED
@else
SELECTED_NAMES=$SELECTED_NAMES[$NAME]
@endif
;
@endif
;
@ifndef $SELECTED_NAMES
NAMES=
@else
NAMES=@repstr:][/,:$SELECTED_NAMES
NAMES=@repstr:[/:$NAMES
NAMES=@repstr:]/:$NAMES
;
NAMES=@file:~echo -n "$NAMES" | tr "," "\n" | sort | tr "\n" "," | head -c-1
@endif
;
#^^$PREFIX: $NAMES$ERASER
;
!!@:NAME_LOOP
;
@:END_NAME_LOOP
;
@ifndef $NAMES
#^^(no names selected)
@endif
;
@endif
