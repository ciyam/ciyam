@retain *
<ansi.cin
;
@ifdef $1
USER=$1
@endif
;
@ifndef $USER
USER=anon
@endif
;
QUIT=
ERROR=
MESSAGE=
RESTRICT=
NOT_TO_SELF=
FOUND_JOINED=
;
.run_script !irc_join "@name=$USER"
;
@ifdef $ERROR
@label END_LOOP
@endif
;
@skip
;
@ifdef $OUTPUT
LINES=@repstr:|/\n:$OUTPUT
;
LOCAL=%LINES:1%
REMOTE=%LINES:2%
ALL_USERS=%LINES:3%
;
@ifeq "$LOCAL" "dummy"
LOCAL=
@else
DISPLAY_USERS=@repstr:@$USER/:$ALL_USERS
@ifdef $DISPLAY_USERS
DISPLAY_USERS=@substr:1:$DISPLAY_USERS
DISPLAY_USERS=@repstr:@/ :$DISPLAY_USERS
DISPLAY_USERS= $DISPLAY_USERS
@endif
#$LOCAL$DISPLAY_USERS
@endif
;
@ifeq "$REMOTE" "dummy"
REMOTE=
@endif
;
@ifdef $REMOTE
NOT_TO_SELF=1
MESSAGE=$REMOTE
@endif
@endif
;
CHECK_PRIOR=1
;
CIYAM_PAUSE_SECONDS=1
;
@:LOOP
;
@ifndef $CHECK_PRIOR
NOT_TO_SELF=
^[hit 'a' for ANSI help, 'q' to quit, 'r' to restrict, 's/v' to scan/view a QR Code or space to type]
;
@ifdef $CIYAM_KEY_PRESSED
;
@ifeq "$CIYAM_KEY_PRESSED" "a"
#
#ANSI escape examples:
#=====================
~grep -o "; Th.*" ansi.cin | cut -c 3-
#
@elif "$CIYAM_KEY_PRESSED" = "q"
QUIT=1
@elif "$CIYAM_KEY_PRESSED" = "r"
@retain NAMES
<names.cin $ALL_USERS
RESTRICT=@repstr:,/.:$NAMES
@elif "$CIYAM_KEY_PRESSED" = "v"
&Enter QR Code: :QR_CODE=
#^^Entered QR Code: $QR_CODE
~qrencode -tANSI $QR_CODE
@elif "$CIYAM_KEY_PRESSED" = "s"
#Scan QR_CODE:
QR_CODE=@file:~zbarcam -1 -q --raw
#^^Scanned QR Code: $QR_CODE
@elif "$CIYAM_KEY_PRESSED" = " "
&:MESSAGE=
@ifneq "$MESSAGE" ""
MESSAGE=@strlit:_[public]$MESSAGE
@endif
@endif
;
@endif
@endif
;
@ifdef $MESSAGE
;
NAMES=ALL
@ifdef $NOT_TO_SELF
NAMES=OTHERS
@endif
;
@ifdef $RESTRICT
NAMES=$RESTRICT
RESTRICT=
@endif
;
ENCODED=@base64:@$MESSAGE
;
.run_script !irc_send_message "@names=$NAMES,@message=$ENCODED"
@ifdef $OUTPUT
#$OUTPUT
@endif
;
@endif
;
@ifdef $QUIT
OUTPUT=
@else
.run_script !irc_fetch_messages
@endif
;
@ifdef $OUTPUT
MESSAGES=$OUTPUT
;
@label MSG_NEXT
;
@:MSG_LOOP
NEXT_MESSAGE=%MESSAGES:1%
;
@ifndef $NEXT_MESSAGE
@label END_MSG_LOOP
@endif
;
@skip
;
@:MSG_NEXT
;
NEXT_MSG_PARTS=@repstr:\: /\n:$NEXT_MESSAGE
;
WHEN_AND_USER=%NEXT_MSG_PARTS:1%
DECODED_MESSAGE=@base64:%NEXT_MSG_PARTS:2%
DECODED_MESSAGE=@substr:1,0:$DECODED_MESSAGE
;
WHEN_AND_USER_LINES=@repstr: /\n:$WHEN_AND_USER
LOCAL=@date:%WHEN_AND_USER_LINES:1%:yyyy-mm-dd hh:mm:ss
;
USER_NAME=%WHEN_AND_USER_LINES:2%
USER_NAME=@padlen:-13, :$USER_NAME:
;
@ifeq "$DECODED_MESSAGE" "[joined]"
FOUND_JOINED=1
@else
MESSAGE_PARTS=@repstr:]/\n:$DECODED_MESSAGE
;
MESSAGE_ROOM_NAME=@strlit:%MESSAGE_PARTS:1%]
MESSAGE_ROOM_LENGTH=@strlen:$MESSAGE_ROOM_NAME
;
DECODED_MESSAGE=@substr:$MESSAGE_ROOM_LENGTH:$DECODED_MESSAGE
;
MESSAGE_ROOM_NAME=@padlen:-20, :$MESSAGE_ROOM_NAME
;
DECODED_MESSAGE=$MESSAGE_ROOM_NAME $DECODED_MESSAGE
@endif
;
NEXT_MESSAGE=[$LOCAL] $USER_NAME $DECODED_MESSAGE
;
PREFIX=
;
@ifdef $MESSAGE
@ifndef $NOT_TO_SELF
PREFIX=^^
@endif
@endif
;
#$PREFIX$NEXT_MESSAGE
;
MESSAGES=%MESSAGES:-1%
;
!!@:MSG_LOOP
;
@:END_MSG_LOOP
;
@endif
;
@ifndef $CHECK_PRIOR
@ifdef $FOUND_JOINED
FOUND_JOINED=
.run_script !irc_join "@name=$USER"
@ifdef $OUTPUT
ALL_USERS=$OUTPUT
@endif
@endif
@endif
;
CHECK_PRIOR=
;
@label NEXT
;
@ifdef $QUIT
@label END_LOOP
@endif
;
@skip
;
@:NEXT
;
MESSAGE=
;
!!@:LOOP
;
@:END_LOOP
