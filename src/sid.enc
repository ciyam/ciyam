string g_sid;

bool g_enc = false;

void get_sid( string& sid )
{
   if( !g_enc || g_sid.empty( ) )
      sid = g_sid;
   else
      hex_encode( sid, g_sid );
}

void set_sid( const string& sid )
{
   clear_key( g_sid );

   if( !sid.length( ) )
      g_sid.erase( );
   else
   {
      if( ( sid.length( ) % 2 ) != 0 )
         g_enc = false;
      else
         g_enc = are_hex_nibbles( sid );

      // NOTE: If the identity is found
      // to be hex digits then store as
      // binary (which stops simplistic
      // discovery by dumping strings).
      if( !g_enc )
         g_sid = sid;
      else
         hex_decode( sid, g_sid );
   }
}
